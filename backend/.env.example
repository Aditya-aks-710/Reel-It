# Copy this file to `.env` and fill in the values you need.
# Everything here has a sensible built-in default, so you can start with an
# empty .env and only set what you want to override.

# --- Server ---
PORT=
NODE_ENV=

# --- Networking / scraping ---
# A desktop browser User-Agent helps Instagram return the public HTML page.
USER_AGENT=

# Where downloaded videos are temporarily stored
DOWNLOAD_DIR=

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=

# --- yt-dlp fallback ---
# Set to 0 to disable the yt-dlp fallback.
YTDLP_ENABLED=
# Python interpreter that has yt-dlp installed (defaults to the project .venv).
PYTHON_PATH=
# Reuse your logged-in browser cookies to beat Instagram's login wall.
# One of: chrome, firefox, edge, brave, chromium, opera, vivaldi, safari
COOKIES_FROM_BROWSER=
# Path to a Netscape-format cookies.txt file (avoids the locked-browser cookie
# problem on Windows). Takes priority over COOKIES_FROM_BROWSER.
COOKIES_FILE=
# Path to an ffmpeg binary/folder. Needed to export audio as mp3 and to merge
# higher-resolution video+audio. Leave blank if ffmpeg is already on PATH.
FFMPEG_PATH=
YTDLP_TIMEOUT_MS=

# --- Resolve cache ---
# How long (ms) a resolved reel is reused before re-running extraction
CACHE_TTL_MS=

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=
